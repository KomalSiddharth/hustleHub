rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Pillar 1)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions (Pillar 3)
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // Founder Deck Tables Collection Rule setup
    match /founderdeck_tables/{tableId} {
      allow read, write: if true; // Open for demo purposes, can be restricted to isSignedIn() later
    }

    // Founder Deck Sessions Collection Rule setup
    match /founderdeck_sessions/{sessionId} {
      allow read, write: if true;
    }

    // Founder Deck App State (Community Chats etc)
    match /founderdeck_app_state/{stateId} {
      allow read, write: if true;
    }
  }
}
